# Root .env for docker-compose ${VAR} interpolation (gitignored).
# This is NOT loaded by the bot (its secrets live in config.docker.yaml). It
# only feeds the graphiti / neo4j services below.

# Graphiti LLM + embeddings (required). Graphiti needs an embedder; OpenAI does
# both. Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Neo4j password for the graph backend (change me).
NEO4J_PASSWORD=change-me

# Optional overrides.
# MODEL_NAME=gpt-4.1-mini
# GRAPHITI_GROUP_ID=main
# SEMAPHORE_LIMIT=10
